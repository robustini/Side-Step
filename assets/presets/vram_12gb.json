  "epochs": 1000,
  "max_steps": 0,
  "dataset_repeats": 1,
  "warmup_steps": 100,
  "weight_decay": 0.01,
  "max_grad_norm": 1.0,
  "seed": 42,
  "optimizer_type": "adamw8bit",
  "scheduler_type": "cosine",
  "cfg_ratio": 0.15,
  "loss_weighting": "none",
  "snr_gamma": 5.0,
  "save_every": 50,
  "save_best": true,
  "save_best_after": 200,
  "early_stop_patience": 0,
  "target_loss": 0.0,
  "log_every": 10,
  "log_heavy_every": 50,
